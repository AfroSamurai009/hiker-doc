    "/v1/user/stories": {
      "get": {
        "summary": "User Stories",
        "description": "⚠️ Billing: 2 requests per call. Returns a list of Story objects.",
        "operationId": "user_stories_v1_user_stories_get",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "User Id"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Amount"
            }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Skip account privacy check",
              "title": "Force"
            },
            "description": "Skip account privacy check"
          }
        ],
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nres = await cl.user_stories_v1(user_id=\"123123\", amount=10)\n",
            "label": "Python"
          }
        ],
        "x-reqs-cost": 2,
        "required": false
      }
    },
