  "paths": {
    "/v2/media/comments": {
      "get": {
        "tags": [
          "Top 5",
          "Post Details",
          "Comments"
        ],
        "summary": "Get media comments (one request return 15 comments)",
        "description": "Get comments on a media. Returns a list of Comment objects.",
        "operationId": "media_comments_v2_media_comments_get",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          },
          {
            "name": "can_support_threading",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Can Support Threading"
            }
          },
          {
            "name": "page_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Page Id"
            }
          }
        ]
      }
    },
