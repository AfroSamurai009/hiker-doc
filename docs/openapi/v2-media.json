          {
            "name": "comment_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Comment Id"
            }
          },
          {
            "name": "min_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Min Id"
            }
          }
        ],
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nreplies = await cl.media_comments_replies_v2(\n    media_id=\"3770903101839112303_185336999\", comment_id=\"18120112390529134\"\n)\n",
            "label": "Python"
          }
        ],
        "required": false
      }
    },
