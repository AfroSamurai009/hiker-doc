          }
        ],
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nres = await cl.media_by_code_v2(code=\"CvipxSKPPn6\")\n",
            "label": "Python"
          }
        ],
        "required": false
      }
    },
