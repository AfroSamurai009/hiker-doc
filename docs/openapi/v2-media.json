  "paths": {
    "/v2/media/comments": {
      "get": {
        "summary": "Get media comments (one request return 15 comments)",
        "description": "Get comments on a media. Returns a list of Comment objects.",
        "operationId": "media_comments_v2_media_comments_get",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          },
          {
            "name": "can_support_threading",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Can Support Threading"
            }
          },
          {
            "name": "page_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Page Id"
            }
          }
        ]
      }
    },
    "/v2/media/info/by/code": {
      "get": {
        "summary": "Returns 200 for found posts and 404 for unavailable or deleted posts. Other responses are not provided. Doesn't return usertags for video.",
        "description": "Get media object",
        "operationId": "media_info_by_code_v2_media_info_by_code_get",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Code"
            }
          }
        ],
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nres = await cl.media_by_code_v2(code=\"CvipxSKPPn6\")\n",
            "label": "Python"
          }
        ],
        "required": false
      }
    },
    "/v2/media/comments/replies": {
