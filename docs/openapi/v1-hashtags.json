                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nitems, max_id = await cl.hashtag_medias_top_chunk_v1(name=\"love\", max_id=None)\n",
            "label": "Python"
          },
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nitems_list = []\nmax_id = None\nwhile True:\n    items, max_id = cl.hashtag_medias_top_chunk_v1(\"love\", max_id=max_id)\n    items_list.extend(items)\n    if not max_id:\n        break\n        ",
