    "/v1/media/comments/chunk": {
      "get": {
        "summary": "Get media comments (one request return 15 comments)",
        "description": "Get comments on a media. Returns a list of Comment objects.",
        "operationId": "media_comments_chunk_v1_media_comments_chunk_get",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Id"
            }
          },
          {
            "name": "min_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "Min Id"
            }
          },
          {
            "name": "max_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "Max Id"
            }
          },
          {
            "name": "can_support_threading",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Can Support Threading"
            }
          }
        ],
        "x-codeSamples": [
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\ncomments, max_id, _ = await cl.media_comments_chunk_v1(\n    id=\"3169346321139418017\", max_id=None\n)\n",
            "label": "Python"
          },
          {
            "lang": "Python",
            "source": "from hikerapi import Client\n\ncl = Client(<ACCESS_KEY>)\nitems_list = []\nmax_id = None\nwhile True:\n    items, max_id = cl.media_comments_chunk_v1(\"3169346321139418017\", max_id=max_id)\n    items_list.extend(items)\n    if not max_id:\n        break\n        ",
            "label": "Python"
          }
        ],
        "required": false
      }
    },
